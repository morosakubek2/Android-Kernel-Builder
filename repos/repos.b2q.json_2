[
  {
    "kernelSource": {
      "name": "android_kernel_samsung_sm8350",
      "repo": "https://github.com/morosakubek2/flip_3_android_kernel_samsung_sm8350",
      "branch": "Flip3-Android16",
      "device": "b2q",
      "defconfig": "gki_defconfig"
    },
    "withKernelSU": false,
    "withSUSFS": false,
    "withLXC": false,
    "toolchains": [
      {
        "repo": "https://github.com/Neutron-Toolchains/clang-build-catalogue",
        "branch": "main",
        "name": "neutron-clang",
        "binPath": ["bin"]
      }
    ],
    "params": {
      "ARCH": "arm64",
      "CC": "clang",
      "externalCommand": {
        "CROSS_COMPILE": "aarch64-linux-gnu-",
        "CROSS_COMPILE_ARM32": "arm-linux-gnueabi-",
        "CLANG_TRIPLE": "aarch64-linux-gnu-",
        "CONFIG_ARCH_QCOM": "y",
        "LD": "ld.lld",
        "AR": "llvm-ar",
        "NM": "llvm-nm",
        "OBJCOPY": "llvm-objcopy",
        "OBJDUMP": "llvm-objdump",
        "READELF": "llvm-readelf",
        "STRIP": "llvm-strip",
        "LLVM": "1"
      }
    },
    "AnyKernel3": {
      "use": true,
      "release": true,
      "repo": "https://github.com/morosakubek2/AnyKernel3",
      "branch": "b2q"
    }
  }
]
